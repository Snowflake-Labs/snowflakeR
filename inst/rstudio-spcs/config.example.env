# Copy to config.env and adjust. Used by build_*.sh and deploy_service.sh

# Snowflake CLI connection name (from ~/.snowflake/config.toml)
export SNOW_CONNECTION=my_account_connection
export SNOW_ROLE=MY_DEPLOY_ROLE

# Snowflake objects
export SNOWFLAKE_ACCOUNT=XY12345
export SNOW_DATABASE=MY_DB
export SNOW_SCHEMA=MY_SCHEMA
export SFNB_IMAGE_REPO=MY_DB.MY_SCHEMA.MY_IMAGES
export SFNB_BUILD_POOL=MY_COMPUTE_POOL
export SFNB_BUILD_EAI=MY_IMAGE_BUILDER_EAI
export IMAGE_BUILDER_NETWORK_RULE=IMAGE_BUILDER_EGRESS
export SNOW_EAI_ROLE=ACCOUNTADMIN

# Service runtime
export RSTUDIO_SERVICE_POOL=MY_COMPUTE_POOL
export RSTUDIO_SERVICE_NAME=MY_DB.MY_SCHEMA.RSTUDIO_SVC
# Snowflake GENERIC_STRING secret name (not the password value).
# Create/rotate: RSTUDIO_PASSWORD='...' ./create_password_secret.sh
export RSTUDIO_PASSWORD_SECRET=RSTUDIO_SERVER_PASSWORD

# Image
export IMAGE_NAME=rstudio-rsnowflake
export IMAGE_TAG=dev
# Full registry path (lowercase); get via: snow spcs image-repository url ...
export REGISTRY_URL=xy12345.registry.snowflakecomputing.com/my_db/my_schema/my_images

# Session defaults injected into the container (RSnowflake + snowflakeR)
export SNOWFLAKE_WAREHOUSE=MY_WH
export SNOWFLAKE_DATABASE=MY_DB
export SNOWFLAKE_SCHEMA=MY_SCHEMA
export SNOWFLAKE_ROLE=MY_ROLE
